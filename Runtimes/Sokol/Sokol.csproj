<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Proxy project for Sokol.NET.

    Sokol.NET/src/sokol/sokol.csproj can't be ProjectReference'd:
    SDebugUI.cs in src/sokol/ imports the Imgui namespace whose types live
    in src/imgui/ (a sibling folder), which sokol.csproj doesn't include.
    So building it standalone fails.

    This project wraps the Sokol.NET source files (from both folders) into
    a proper library that the rest of the solution can reference cleanly.
  -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>Sokol</AssemblyName>
    <RootNamespace>Sokol</RootNamespace>
    <!--
      These warnings come from the vendored Sokol.NET bindings we include
      verbatim via the Compile globs below — they aren't our code to fix:
        CS9084 - struct member is a readonly ref returning field
        CS9087 - returning ref of a member of a ref-returning property
        CS8600 - converting null literal to non-nullable type
        CS8603 - possible null reference return
    -->
    <NoWarn>CS9084;CS9087;CS8600;CS8603</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\Sokol.NET\src\sokol\*.cs" Link="sokol\%(Filename)%(Extension)" />
    <Compile Include="..\..\Sokol.NET\src\sokol\generated\*.cs" Link="sokol\generated\%(Filename)%(Extension)" />
    <Compile Include="..\..\Sokol.NET\src\imgui\*.cs" Link="imgui\%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
