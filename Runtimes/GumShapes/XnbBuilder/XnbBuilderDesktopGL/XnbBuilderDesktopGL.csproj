<Project Sdk="Microsoft.NET.Sdk">

	<!--
		Builds the Apos.Shapes shader XNB for DesktopGL (OpenGL).
		This project is never run - only built.
	-->

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="..\Program.cs" Link="Program.cs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Apos.Shapes.KNI" Version="0.6.8" />
		<PackageReference Include="nkast.Xna.Framework" Version="4.2.9001" PrivateAssets="All" />
		<PackageReference Include="nkast.Xna.Framework.Content" Version="4.2.9001" PrivateAssets="All" />
		<PackageReference Include="nkast.Xna.Framework.Graphics" Version="4.2.9001" PrivateAssets="All" />
		<PackageReference Include="nkast.Xna.Framework.Game" Version="4.2.9001" PrivateAssets="All" />
		<PackageReference Include="nkast.Xna.Framework.Content.Pipeline.Builder" Version="4.2.9001" PrivateAssets="All" />
		<PackageReference Include="nkast.Kni.Platform.SDL2.GL" Version="4.2.9001" PrivateAssets="All" />
	</ItemGroup>

</Project>
