<Project>

  <!-- Ship the prebuilt Apos.Shapes shader XNB for platforms we cover. The upstream
       Apos.Shapes content pipeline is blocked at the package boundary via PrivateAssets
       on the Apos.Shapes PackageReference in MonoGameGumShapes.csproj, so its
       buildTransitive/.props never runs in our consumers — no SkipAposShapeContent setter
       or follow-up Remove needed. Other MonoGamePlatform values (Android, iOS, MacOS
       Metal, etc.) get no XNB from us; consumers on those platforms must reference
       Apos.Shapes directly (restoring its content pipeline) or supply the XNB themselves. -->

  <!-- DesktopGL (OpenGL) -->
  <ItemGroup Condition="'$(MonoGamePlatform)' == 'DesktopGL'">
    <Content Include="$(MSBuildThisFileDirectory)MonoGame/Content/DesktopGL/apos-shapes.xnb"
             Link="Content/apos-shapes.xnb"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- WindowsDX (DirectX/HLSL) -->
  <ItemGroup Condition="'$(MonoGamePlatform)' == 'WindowsDX'">
    <Content Include="$(MSBuildThisFileDirectory)MonoGame/Content/WindowsDX/apos-shapes.xnb"
             Link="Content/apos-shapes.xnb"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
