<Project>

  <!-- Ship the prebuilt Apos.Shapes shader XNB for platforms we cover. The upstream
       Apos.Shapes.KNI content pipeline is blocked at the package boundary via PrivateAssets
       on the Apos.Shapes.KNI PackageReference in KniGumShapes.csproj, so its
       buildTransitive/.props never runs in our consumers — no SkipAposShapeContent setter
       or follow-up Remove needed. Platforms not covered below (Android, iOS, etc.) get no
       XNB from us; consumers there must reference Apos.Shapes.KNI directly (restoring its
       content pipeline) or supply the XNB themselves. -->

  <!-- DesktopGL -->
  <ItemGroup Condition="'$(KniPlatform)' == 'DesktopGL'">
    <Content Include="$(MSBuildThisFileDirectory)Content/DesktopGL/apos-shapes.xnb"
             Link="Content/apos-shapes.xnb"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Windows/DirectX -->
  <ItemGroup Condition="'$(KniPlatform)' == 'Windows'">
    <Content Include="$(MSBuildThisFileDirectory)Content/Windows/apos-shapes.xnb"
             Link="Content/apos-shapes.xnb"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- BlazorGL/WebGL: copy XNB to project's wwwroot/Content/ at build time,
       matching how the KNI content pipeline outputs BlazorGL content -->
  <Target Name="CopyAposShapesXnbToWwwroot" BeforeTargets="BeforeBuild"
          Condition="'$(KniPlatform)' == 'BlazorGL'">
    <MakeDir Directories="$(MSBuildProjectDirectory)/wwwroot/Content" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)Content/BlazorGL/apos-shapes.xnb"
          DestinationFolder="$(MSBuildProjectDirectory)/wwwroot/Content"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- All other platforms: Apos.Shapes compiles the shader normally -->

</Project>
