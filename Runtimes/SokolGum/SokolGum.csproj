		<Compile Include="..\..\MonoGameGum\Forms\DefaultFromFileVisuals\*.cs" Link="Forms\DefaultFromFileVisuals\%(Filename)%(Extension)" />
	</ItemGroup>

	<ItemGroup>
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Image.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Menu.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\MenuItem.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\PasswordBox.cs" />
	</ItemGroup>

	<ItemGroup>
		<!--
		Global using so shared source files (e.g. MonoGameGum/Forms/**) don't need
		explicit `using SokolGum;` inside #elif SOKOL import blocks. Types like
		Color and Texture2D from SokolGum resolve here. Mirrors the
		`<Using Include="Raylib_cs" />` in RaylibGum.csproj.
		-->
		<Using Include="SokolGum" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="TextCopy" Version="6.2.1" Condition="!$(TargetFramework.Contains('ios'))" />
	</ItemGroup>

</Project>
