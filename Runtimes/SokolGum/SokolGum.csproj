		<Compile Remove="..\..\MonoGameGum\Forms\Controls\ListBoxItem.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Panel.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Primitives\ButtonBase.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Primitives\RangeBase.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\RadioButton.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\RowDefinition.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\ScrollBar.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\ScrollViewer.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Slider.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Splitter.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\StackPanel.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\TextBox.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\TextBoxBase.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\ToggleButton.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\Tooltip.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\ToolTipService.cs" />
		<Compile Remove="..\..\MonoGameGum\Forms\Controls\UserControl.cs" />
	</ItemGroup>

	<ItemGroup>
		<!--
		Global using so shared source files (e.g. MonoGameGum/Forms/**) don't need
		explicit `using SokolGum;` inside #elif SOKOL import blocks. Types like
		Color and Texture2D from SokolGum resolve here. Mirrors the
		`<Using Include="Raylib_cs" />` in RaylibGum.csproj.
		-->
		<Using Include="SokolGum" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="TextCopy" Version="6.2.1" Condition="!$(TargetFramework.Contains('ios'))" />
	</ItemGroup>

</Project>
