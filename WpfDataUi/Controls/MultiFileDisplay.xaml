<UserControl
    x:Class="WpfDataUi.Controls.MultiFileDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WpfDataUi.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfDataUi.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="80"
    MaxHeight="260"
    d:DesignWidth="200"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:AddDoubleConverter x:Key="AddDoubleConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="Label"
            MinWidth="100"
            Padding="4,4,4,0"
            VerticalAlignment="Center"
            TextWrapping="Wrap">
            Property Label:
        </TextBlock>
        <ListBox
            x:Name="ListBox"
            Grid.Row="1"
            Background="{DynamicResource Frb.Brushes.Field.Background}"
            BorderBrush="{DynamicResource Frb.Brushes.Border.Secondary}"
            BorderThickness="1"
            KeyDown="ListBox_KeyDown"
            PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
            SelectionChanged="ListBox_SelectionChanged" />
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            Orientation="Horizontal">
            <Button
                MinWidth="48"
                MinHeight="24"
                Margin="0,2,2,2"
                Click="AddButtonClicked"
                Content="Add..." />
            <Button
                x:Name="RemoveButton"
                MinWidth="48"
                MinHeight="24"
                Margin="0,2,2,2"
                Click="RemoveButtonClicked"
                Content="Remove"
                Visibility="Collapsed" />
            <Button
                x:Name="MoveUpButton"
                MinWidth="24"
                MinHeight="24"
                Margin="0,2,2,2"
                Click="MoveUpButtonClicked"
                Content="Up"
                Visibility="Collapsed" />
            <Button
                x:Name="MoveDownButton"
                MinWidth="24"
                MinHeight="24"
                Margin="0,2,2,2"
                Click="MoveDownButtonClicked"
                Content="Down"
                Visibility="Collapsed" />
        </StackPanel>
        <TextBlock
            x:Name="HintTextBlock"
            Grid.Row="3"
            Margin="0,0,-4,0"
            Padding="8,0,0,0"
            FontSize="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type local:MultiFileDisplay}}, Converter={StaticResource AddDoubleConverter}, ConverterParameter=-2}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
