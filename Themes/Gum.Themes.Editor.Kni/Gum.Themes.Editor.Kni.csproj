<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Editor.Kni</PackageId>
    <Version>2026.4.5.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>An editor-focused theme for Gum UI. Provides styled visuals for building tool and editor interfaces with KNI and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\Gum.Themes.Editor.MonoGame\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Gum.Themes.Editor.MonoGame\**\*.cs" />
    <Compile Remove="..\Gum.Themes.Editor.MonoGame\obj\**" />
    <!-- Shared platform shim (lives outside the MonoGame project folder, so the glob above
         does not pick it up). -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- KernSmith is a runtime dependency (the theme generates fonts at runtime), so it must flow
         transitively to consumers — do NOT mark it PrivateAssets=All. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.KniGum\KernSmith.KniGum.csproj" />
    <PackageReference Include="nkast.Xna.Framework" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Graphics" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Input" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\KniGum\KniGum.csproj" />
  </ItemGroup>
</Project>
