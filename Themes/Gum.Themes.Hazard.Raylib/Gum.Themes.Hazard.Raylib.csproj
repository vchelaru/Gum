<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <!-- Selects the raylib branch of the shared theme sources (Color via Raylib_cs; raylib font
         creator + no-op shape init in the ThemePlatform/ThemeShapePlatform shims). -->
    <DefineConstants>$(DefineConstants);RAYLIB</DefineConstants>

    <PackageId>Gum.Themes.Hazard.Raylib</PackageId>
    <Version>1.0.0</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>Hazard theme for Gum Forms - an industrial space-salvage HUD look (hazard-yellow on warm black, square-cornered chrome, Saira Condensed type). Provides styled visuals for Gum Forms controls with raylib and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\Gum.Themes.Hazard.MonoGame\README.md" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Hazard.MonoGame\Content\Fonts\SairaCondensed-OFL.txt" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Hazard.MonoGame\Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Source-share the MonoGame variant's .cs files; the RAYLIB symbol above swaps the
         per-backend branches. The shims live outside that folder, so they are linked explicitly. -->
    <Compile Include="..\Gum.Themes.Hazard.MonoGame\**\*.cs" />
    <Compile Remove="..\Gum.Themes.Hazard.MonoGame\obj\**" />
    <Compile Remove="..\Gum.Themes.Hazard.MonoGame\bin\**" />
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Re-embed the TTFs from the MonoGame project's Content\Fonts folder, mapped under this
         assembly's Content\Fonts via <Link> so the resource name resolves to
         "Gum.Themes.Hazard.Raylib.Content.Fonts.<file>" - matching what
         HazardTheme.RegisterEmbeddedFont derives from the assembly name. -->
    <EmbeddedResource Include="..\Gum.Themes.Hazard.MonoGame\Content\Fonts\SairaCondensed-Regular.ttf">
      <Link>Content\Fonts\SairaCondensed-Regular.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Hazard.MonoGame\Content\Fonts\SairaCondensed-SemiBold.ttf">
      <Link>Content\Fonts\SairaCondensed-SemiBold.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Hazard.MonoGame\Content\Fonts\DejaVuSansMono.ttf">
      <Link>Content\Fonts\DejaVuSansMono.ttf</Link>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\Runtimes\RaylibGum\RaylibGum.csproj" />
    <!-- KernSmith is a runtime dependency (the theme generates fonts at runtime), so it flows
         transitively to consumers - not PrivateAssets=All. No shapes package: RaylibGum
         renders RectangleRuntime / CircleRuntime natively. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.RaylibGum\KernSmith.RaylibGum.csproj" />
  </ItemGroup>
</Project>
