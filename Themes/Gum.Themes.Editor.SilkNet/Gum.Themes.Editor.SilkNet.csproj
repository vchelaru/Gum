<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <!-- Selects the Skia branch of the shared theme sources (Color via SkiaSharp.SKColor, the
         no-op font-creator wiring in ThemePlatform). The .MonoGame / .Kni / .Raylib variants
         leave this undefined. -->
    <DefineConstants>$(DefineConstants);SKIA</DefineConstants>

    <PackageId>Gum.Themes.Editor.SilkNet</PackageId>
    <Version>2026.4.5.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>An editor-focused theme for Gum UI. Provides styled visuals for building tool and editor interfaces with Skia/SilkNet and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\Gum.Themes.Editor.MonoGame\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Source-share every theme .cs from the MonoGame variant; the SKIA symbol above swaps the
         per-backend branches. The shim lives outside that folder, so it is linked explicitly. -->
    <Compile Include="..\Gum.Themes.Editor.MonoGame\**\*.cs" />
    <Compile Remove="..\Gum.Themes.Editor.MonoGame\obj\**" />
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Color (SkiaSharp.SKColor) resolves through this package on the SKIA branch of the theme
         sources; the theme imports it explicitly (no global using). Skia needs no KernSmith
         atlas-baking dependency: it rasterizes TTFs natively via GumFontMapper. -->
    <PackageReference Include="SkiaSharp" Version="3.119.1" />
  </ItemGroup>
  <ItemGroup>
    <!-- Gum.SilkNet: the real game-host runtime (window/input + Skia rendering). Deliberately NOT
         SkiaGum.csproj: SilkNetGum.csproj is a self-contained assembly that file-links SkiaGum's
         source rather than referencing it, so it has its own independently-compiled copies of the
         GueDeriving/Forms visual types. A theme built against SkiaGum.csproj directly would produce
         incompatible types for a SilkNet-hosted app (#3671). -->
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\Runtimes\SilkNetGum\SilkNetGum.csproj" />
  </ItemGroup>
</Project>
