<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Retro95.Kni</PackageId>
    <Version>2026.5.11.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>A retro Windows 95 / "Classic" theme for Gum UI. Provides styled visuals for Gum Forms controls with raised/sunken beveled chrome, navy selection bands, and the canonical battleship-gray (#C0C0C0) palette, for KNI and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\Gum.Themes.Retro95.MonoGame\README.md" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Retro95.MonoGame\Content\Fonts\OFL.txt" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Retro95.MonoGame\Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Gum.Themes.Retro95.MonoGame\**\*.cs" />
    <Compile Remove="..\Gum.Themes.Retro95.MonoGame\obj\**" />
    <!-- Shared platform shims (live outside the MonoGame project folder, so the glob misses them). -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Re-embed TTFs from the MonoGame project's Content\Fonts folder under
         this assembly's Content\Fonts via <Link>, so the resource name resolves
         to "Gum.Themes.Retro95.Kni.Content.Fonts.<file>" — matching what
         Retro95Theme.RegisterEmbeddedFont derives from the assembly name. -->
    <EmbeddedResource Include="..\Gum.Themes.Retro95.MonoGame\Content\Fonts\Nunito-Regular.ttf">
      <Link>Content\Fonts\Nunito-Regular.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Retro95.MonoGame\Content\Fonts\Nunito-Bold.ttf">
      <Link>Content\Fonts\Nunito-Bold.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Retro95.MonoGame\Content\Fonts\DejaVuSansMono.ttf">
      <Link>Content\Fonts\DejaVuSansMono.ttf</Link>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.KniGum\KernSmith.KniGum.csproj" />
    <PackageReference Include="nkast.Xna.Framework" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Graphics" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Input" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\KniGum\KniGum.csproj" />
    <ProjectReference Include="..\..\Runtimes\GumShapes\KniGumShapes.csproj" />
  </ItemGroup>
</Project>
