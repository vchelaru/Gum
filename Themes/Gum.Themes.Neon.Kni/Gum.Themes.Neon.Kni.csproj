<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Neon.Kni</PackageId>
    <Version>2026.5.11.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>A neon / cyberpunk theme for Gum UI. Provides styled visuals for Gum Forms controls with saturated cyan glow, near-square corners, and the Share Tech Mono / Orbitron typefaces, for KNI and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\Gum.Themes.Neon.MonoGame\README.md" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\ShareTechMono-LICENSE.txt" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\Orbitron-LICENSE.txt" Pack="true" PackagePath="\" />
    <None Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Gum.Themes.Neon.MonoGame\**\*.cs" />
    <Compile Remove="..\Gum.Themes.Neon.MonoGame\obj\**" />
    <!-- Shared platform shims (live outside the MonoGame project folder, so the glob misses them). -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Re-embed the TTFs from the MonoGame project's Content\Fonts folder
         under this assembly's Content\Fonts via <Link>, so the resource name
         resolves to "Gum.Themes.Neon.Kni.Content.Fonts.<file>" — matching what
         NeonTheme.RegisterEmbeddedFont derives from assembly name. -->
    <EmbeddedResource Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\ShareTechMono-Regular.ttf">
      <Link>Content\Fonts\ShareTechMono-Regular.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\Orbitron-Regular.ttf">
      <Link>Content\Fonts\Orbitron-Regular.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\Orbitron-Bold.ttf">
      <Link>Content\Fonts\Orbitron-Bold.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\Orbitron-Black.ttf">
      <Link>Content\Fonts\Orbitron-Black.ttf</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\Gum.Themes.Neon.MonoGame\Content\Fonts\DejaVuSansMono.ttf">
      <Link>Content\Fonts\DejaVuSansMono.ttf</Link>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.KniGum\KernSmith.KniGum.csproj" />
    <PackageReference Include="nkast.Xna.Framework" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Graphics" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="nkast.Xna.Framework.Input" Version="4.2.9001">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\KniGum\KniGum.csproj" />
    <ProjectReference Include="..\..\Runtimes\GumShapes\KniGumShapes.csproj" />
  </ItemGroup>
</Project>
