<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Bubblegum.MonoGame</PackageId>
    <Version>2026.5.11.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>A pastel pink casual-game theme for Gum UI. Provides styled visuals for Gum Forms controls with rounded pill buttons, soft drop shadows, and the Nunito typeface, for MonoGame and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\OFL.txt" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shared platform shims: isolate the per-backend font-creator + shape-renderer wiring so
         BubblegumTheme stays platform-agnostic and source-shares cleanly into .Kni and .Raylib. -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Nunito (SIL OFL) bundled as the theme typeface. Four-style coverage:
         Regular / Bold / Italic / BoldItalic. The bubblegum design uses weights
         700-900; all collapse onto the "Bold" slot. -->
    <EmbeddedResource Include="Content\Fonts\Nunito-Regular.ttf" />
    <EmbeddedResource Include="Content\Fonts\Nunito-Bold.ttf" />
    <EmbeddedResource Include="Content\Fonts\Nunito-Italic.ttf" />
    <EmbeddedResource Include="Content\Fonts\Nunito-BoldItalic.ttf" />
    <!-- DejaVu Sans Mono is bundled as the "icon font" for glyphs Nunito doesn't
         cover (Dingbats / Geometric Shapes blocks: ✓ ▼ etc.). Registered under
         the family name "Nunito Icons" in BubblegumTheme so visual code is
         decoupled from the specific TTF. Same pattern as Dark Pro. -->
    <EmbeddedResource Include="Content\Fonts\DejaVuSansMono.ttf" />
  </ItemGroup>
  <ItemGroup>
    <!-- KernSmith is a runtime dependency (BubblegumTheme.Apply constructs
         KernSmithFontCreator and calls RegisterFont). Flows transitively. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.MonoGameGum\KernSmith.MonoGameGum.csproj" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\MonoGameGum.csproj" />
    <ProjectReference Include="..\..\Runtimes\GumShapes\MonoGameGumShapes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Lets Tests/Gum.Themes.Tests call the internal ConfigureStyling() directly to exercise
         the 4-token guardrail sync without going through Apply(), which needs a real
         GraphicsDevice for font wiring and can't run headlessly in a unit test. -->
    <InternalsVisibleTo Include="Gum.Themes.Tests" />
  </ItemGroup>
</Project>
