<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Template.MonoGame</PackageId>
    <Version>1.0.0</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>Starting point for building a new Gum theme. Clone this project, rename Template -> YourTheme, fill in the palette from your CSS, swap the fonts, and restyle the visuals. Provides styled visuals for Gum Forms controls with MonoGame and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- This is a template, not a shipped package: IsPackable=false keeps `dotnet pack`
         (the CI publish path) from emitting a .nupkg, and GeneratePackageOnBuild=false keeps
         local builds from doing so. Flip both once you have cloned it into a real theme. The
         rest of the packaging metadata above is left intact so the clone is publish-ready. -->
    <IsPackable>false</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\OFL.txt" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\Nunito-OFL.txt" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shared platform shims: isolate the per-backend font-creator + shape-renderer wiring so
         TemplateTheme stays platform-agnostic and source-shares cleanly into .Kni and .Raylib. -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- TTFs are embedded so TemplateTheme.Apply can register them via the
         KernSmithFontCreator byte[] overload, sparing consumers from copying font
         files into their own Content folder. Swap these for your theme's fonts and
         update the family names + RegisterBundledFonts() in TemplateTheme. -->
    <EmbeddedResource Include="Content\Fonts\DMMono-Regular.ttf" />
    <EmbeddedResource Include="Content\Fonts\DMMono-Medium.ttf" />
    <EmbeddedResource Include="Content\Fonts\DMMono-Italic.ttf" />
    <EmbeddedResource Include="Content\Fonts\DMMono-MediumItalic.ttf" />
    <!-- Body family (the second family demonstrated by this template's multi-font
         support). Nunito is a humanist sans contrasting DM Mono's monospace display. -->
    <EmbeddedResource Include="Content\Fonts\Nunito-Regular.ttf" />
    <EmbeddedResource Include="Content\Fonts\Nunito-Bold.ttf" />
    <!-- DejaVu Sans Mono is bundled as the "icon font" for glyphs the body font
         doesn't cover (Dingbats / Geometric Shapes blocks: check, close, arrows).
         Registered under a distinct family name in TemplateTheme so visual code is
         decoupled from the specific TTF. -->
    <EmbeddedResource Include="Content\Fonts\DejaVuSansMono.ttf" />
  </ItemGroup>
  <ItemGroup>
    <!-- KernSmith is a runtime dependency of the theme (TemplateTheme.Apply
         constructs KernSmithFontCreator and calls RegisterFont). It must flow
         transitively to consumers - hence no PrivateAssets here. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.MonoGameGum\KernSmith.MonoGameGum.csproj" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\MonoGameGum.csproj" />
    <ProjectReference Include="..\..\Runtimes\GumShapes\MonoGameGumShapes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Lets Tests/Gum.Themes.Tests call the internal ConfigureStyling() directly to exercise
         the 4-token guardrail sync without going through Apply(), which needs a real
         GraphicsDevice for font wiring and can't run headlessly in a unit test. -->
    <InternalsVisibleTo Include="Gum.Themes.Tests" />
  </ItemGroup>
</Project>
