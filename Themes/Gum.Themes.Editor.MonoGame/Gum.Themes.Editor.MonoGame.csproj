<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Editor.MonoGame</PackageId>
    <Version>2026.4.5.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>An editor-focused theme for Gum UI. Provides styled visuals for building tool and editor interfaces with MonoGame and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shared platform shim: isolates the per-backend font-creator wiring so EditorTheme stays
         platform-agnostic and source-shares cleanly into the .Kni and .Raylib variants. -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- KernSmith is a runtime dependency (the theme generates fonts at runtime), so it must flow
         transitively to consumers — do NOT mark it PrivateAssets=All. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.MonoGameGum\KernSmith.MonoGameGum.csproj" />
	<PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\MonoGameGum.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Lets Tests/Gum.Themes.Tests call the internal ConfigureStyling() directly to exercise
         the 4-token guardrail sync without going through Apply(), which needs a real
         GraphicsDevice for font wiring and can't run headlessly in a unit test. -->
    <InternalsVisibleTo Include="Gum.Themes.Tests" />
  </ItemGroup>
</Project>
