<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>

    <PackageId>Gum.Themes.Meadow.MonoGame</PackageId>
    <Version>2026.5.31.1</Version>
    <Authors>Gum Contributors</Authors>
    <RepositoryUrl>https://github.com/vchelaru/Gum</RepositoryUrl>
    <Description>A cozy cottagecore theme for Gum UI in cream, sage, peach, teal, sky-blue, and coral. Provides styled visuals for Gum Forms controls with chunky pill buttons, dashed-outline panels, soft drop shadows, and the Baloo 2 + Quicksand typefaces, for MonoGame and Gum.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\Baloo2-OFL.txt" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\Quicksand-OFL.txt" Pack="true" PackagePath="\" />
    <None Include="Content\Fonts\DejaVuSansMono-LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- Shared platform shims: isolate the per-backend font-creator + shape-renderer wiring so
         MeadowTheme stays platform-agnostic and source-shares cleanly into .Kni and .Raylib. -->
    <Compile Include="..\Shared\ThemePlatform.cs" Link="ThemePlatform.cs" />
    <Compile Include="..\Shared\ThemeShapePlatform.cs" Link="ThemeShapePlatform.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- TTFs are embedded so MeadowTheme.Apply can register them via the
         KernSmithFontCreator byte[] overload, sparing consumers from copying
         font files into their own Content folder. Baloo 2 (display) and
         Quicksand (body) are weight-only families; SemiBold/Medium fill the
         Normal slot and Bold fills the Bold slot (see RegisterBundledFonts). -->
    <EmbeddedResource Include="Content\Fonts\Baloo2-SemiBold.ttf" />
    <EmbeddedResource Include="Content\Fonts\Baloo2-Bold.ttf" />
    <EmbeddedResource Include="Content\Fonts\Quicksand-Medium.ttf" />
    <EmbeddedResource Include="Content\Fonts\Quicksand-Bold.ttf" />
    <!-- DejaVu Sans Mono is bundled as the "icon font" for glyphs the body
         fonts don't cover (Dingbats / Geometric Shapes: check, dropdown arrow).
         Registered under a distinct family name in MeadowTheme. -->
    <EmbeddedResource Include="Content\Fonts\DejaVuSansMono.ttf" />
  </ItemGroup>
  <ItemGroup>
    <!-- KernSmith is a runtime dependency of the theme (MeadowTheme.Apply
         constructs KernSmithFontCreator and calls RegisterFont). It must flow
         transitively to consumers - hence no PrivateAssets here. -->
    <ProjectReference Include="..\..\Integrations\KernSmith\KernSmith.MonoGameGum\KernSmith.MonoGameGum.csproj" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\MonoGameGum\MonoGameGum.csproj" />
    <ProjectReference Include="..\..\Runtimes\GumShapes\MonoGameGumShapes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Lets Tests/Gum.Themes.Tests call the internal ConfigureStyling() directly to exercise
         the 4-token guardrail sync without going through Apply(), which needs a real
         GraphicsDevice for font wiring and can't run headlessly in a unit test. -->
    <InternalsVisibleTo Include="Gum.Themes.Tests" />
  </ItemGroup>
</Project>
