<Project Sdk="Microsoft.NET.Sdk">

	<!--
		Gum.Presentation — headless (net8.0) home for tool ViewModels and the
		framework-neutral presentation logic they depend on. See ADR-0005.

		This assembly must NEVER reference WPF or WinForms. The project-reference
		boundary is what makes the logic<->view separation compiler-enforced
		(ADR-0003): a stray System.Windows.* use here fails the build instead of
		passing on convention. Keep dependencies limited to Gum.ProjectServices
		(which transitively pulls in GumCommon) plus the .NET BCL.
	-->
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<LangVersion>12.0</LangVersion>
		<NoWarn>1591</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<!-- UndoManagerTests reach UndoManager's internal UndoLocks. They now live in the dedicated
		     headless Gum.Presentation.Tests project (migrated out of GumToolUnitTests, ADR-0005
		     Phase 3). -->
		<InternalsVisibleTo Include="Gum.Presentation.Tests" />
		<!-- DeleteLogicTests still lives in GumToolUnitTests and reaches DeleteLogic's internal
		     PerformConfirmedSingleInstanceDelete/PerformConfirmedMixedTypeDelete/BuildDeleteDialogMessage.
		     DeleteLogic moved here from Gum.csproj (ADR-0005 Phase 3); Gum.csproj already granted
		     this via Gum/Properties/AssemblyInfo.cs, so the grant moves with the class. Drop this
		     once the tests migrate into Gum.Presentation.Tests, mirroring UndoManagerTests. -->
		<InternalsVisibleTo Include="GumToolUnitTests" />
	</ItemGroup>

	<ItemGroup>
		<!-- DialogViewModel uses RelayCommand. CommunityToolkit.Mvvm is framework-neutral
		     (no WPF/WinForms), so it does not violate the headless boundary above. -->
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<!-- AnimationViewModel/AnimatedKeyframeViewModel use InterpolationType/Easing. This is an
		     easing/tweening library under the FlatRedBall brand (not the FRB engine) and has no
		     WPF/WinForms dependency, so it does not violate the headless boundary above. Pin matches
		     StateAnimationPlugin.csproj so a single bump propagates predictably. -->
		<PackageReference Include="FlatRedBall.InterpolationCore" Version="2025.4.22.1" />
		<!-- RecentProjectReference (IProjectManager.RecentProjects) uses [JsonIgnore] on its computed
		     FilePath property. Newtonsoft.Json has no WPF/WinForms dependency and is already pulled in
		     transitively via Gum.ProjectServices; pin matches that project's version explicitly since
		     this assembly's own source now references it directly. -->
		<PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
		<!-- ThemingDialogViewModel takes IOptionsMonitor&lt;ThemeSettings&gt;. Microsoft.Extensions.Options
		     has no WPF/WinForms dependency; pin matches Gum.csproj's Microsoft.Extensions.Hosting version
		     (which pulls Options in transitively there) so a single bump propagates predictably. -->
		<PackageReference Include="Microsoft.Extensions.Options" Version="9.0.0" />
		<!-- ImageHeader's malformed-file fallback path constructs a System.Drawing.Bitmap. This has
		     no WPF/WinForms dependency (Gum.csproj already references it for the same class); pin
		     matches Gum.csproj's version so a single bump propagates predictably. -->
		<PackageReference Include="System.Drawing.Common" Version="10.0.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Gum.ProjectServices\Gum.ProjectServices.csproj" />
		<!-- VariableReferenceLogic parses VariableReferences lines with Roslyn (GetAssignmentSyntax)
		     and evaluates them via EvaluatedSyntax. GumExpressions has no WPF/WinForms dependency
		     and already pulls in Microsoft.CodeAnalysis.CSharp transitively. -->
		<ProjectReference Include="..\..\Runtimes\GumExpressions\GumExpressions.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- SetVariableLogic calls the IRenderableIpso.GetFileWidthAndHeightOrDefault extension method.
		     This file is genuinely shared runtime source (SilkNetGum/SkiaGum also link it directly by
		     relative path), so it stays physically in Gum/RenderingLibrary/ rather than moving under
		     this tool-only assembly; link it in the same way GumCommon.csproj links shared Gum/ files
		     (e.g. Managers/INameVerifier.cs). -->
		<Compile Include="..\..\Gum\RenderingLibrary\IPositionedSizedObjectExtensionMethods.cs" Link="RenderingLibrary\IPositionedSizedObjectExtensionMethods.cs" />
	</ItemGroup>

</Project>
