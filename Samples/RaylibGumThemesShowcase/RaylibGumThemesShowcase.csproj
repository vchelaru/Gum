<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="7.0.1" />
  </ItemGroup>

  <ItemGroup>
    <!-- Source-share the exact showcase screens from the MonoGame host so the two stay identical
         for side-by-side comparison. They are platform-neutral Gum.Forms code. -->
    <Compile Include="..\MonoGameGumThemesShowcase\Screens\*.cs" Link="Screens\%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\Runtimes\RaylibGum\RaylibGum.csproj" />
    <!-- The theme packages are the only Gum reference a consumer needs: each transitively brings
         KernSmith.RaylibGum (runtime font generation), so this sample wires nothing extra. -->
    <ProjectReference Include="..\..\Themes\Gum.Themes.Editor.Raylib\Gum.Themes.Editor.Raylib.csproj" />
    <ProjectReference Include="..\..\Themes\Gum.Themes.DarkPro.Raylib\Gum.Themes.DarkPro.Raylib.csproj" />
  </ItemGroup>

</Project>
