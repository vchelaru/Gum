<Project Sdk="Microsoft.NET.Sdk">

  <!-- Throwaway clean-room repro (NO Gum) for the RichTextKit outline miter-spike bug: RichTextKit
       paints its halo (Style.HaloColor/HaloWidth) as a stroked outline but never sets StrokeJoin, so
       SkiaSharp defaults to Miter and spikes out at acute glyph vertices. Renders the halo next to a
       hand-rolled miter stroke (same spikes) and a hand-rolled round stroke (clean) to isolate the
       cause. Silk.NET + ANGLE/GLES + SkiaSharp bootstrap mirrors Samples/SilkNetGum/SilkNetGumSample. -->

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Same versions SkiaGum pairs (Runtimes/SkiaGum/SkiaGum.csproj) so the repro exercises the
         exact RichTextKit/SkiaSharp combo Gum ships. -->
    <PackageReference Include="SkiaSharp" Version="3.119.1" />
    <PackageReference Include="Topten.RichTextKit" Version="0.4.167" />
    <PackageReference Include="Silk.NET.OpenGLES" Version="2.22.0" />
    <PackageReference Include="Silk.NET.SDL" Version="2.21.0" />
    <PackageReference Include="Silk.NET.Windowing.Sdl" Version="2.21.0" />
    <PackageReference Include="Silk.NET.EGL" Version="1.9.0" />
    <PackageReference Include="Silk.NET.EGL.Extensions.ANGLE" Version="1.9.0" />
    <PackageReference Include="Silk.NET.EGL.Extensions.EXT" Version="1.9.0" />
  </ItemGroup>

  <!-- ANGLE native libs the SDL hints load at context-creation time. Linked from the SilkNet sample
       rather than duplicated into git. -->
  <ItemGroup>
    <None Include="..\SilkNetGum\SilkNetGumSample\libEGL.dll" Link="libEGL.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\SilkNetGum\SilkNetGumSample\libGLESv2.dll" Link="libGLESv2.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
