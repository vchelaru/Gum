<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<!-- Must differ from the referenced Runtimes/SilkNetGum/SilkNetGum.csproj's assembly name
		     ("SilkNetGum", the Gum.SilkNet runtime package). Both projects share the "SilkNetGum"
		     csproj filename, so without this override their same-named output DLLs collide in this
		     project's bin folder and the runtime's copy gets clobbered by this project's own thin
		     exe DLL, producing a TypeLoadException for Gum.GumService at runtime (#3652). -->
		<AssemblyName>SilkNetGumSample</AssemblyName>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>True</AllowUnsafeBlocks>
		<PublishAot>true</PublishAot>
		<DefineConstants Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(DefineConstants);WINDOWS</DefineConstants>
		<DefineConstants Condition="$([MSBuild]::IsOSPlatform('OSX'))">$(DefineConstants);MACOS</DefineConstants>
		<DefineConstants Condition="'$(TargetFramework)' == 'net7.0-ios'">$(DefineConstants);IOS</DefineConstants>
		<DefineConstants Condition="'$(TargetFramework)' == 'net7.0-maccatalyst'">$(DefineConstants);MACCATALYST</DefineConstants>
		<DefineConstants Condition="'$(TargetFramework)' == 'net7.0-android'">$(DefineConstants);ANDROID</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia.Skia" Version="11.2.3" />
		<PackageReference Include="Silk.NET.EGL" Version="1.9.0" />
		<PackageReference Include="Silk.NET.EGL.Extensions.ANGLE" Version="1.9.0" />
		<PackageReference Include="Silk.NET.EGL.Extensions.EXT" Version="1.9.0" />
		<PackageReference Include="Silk.NET.OpenGLES" Version="2.22.0" />
		<PackageReference Include="Silk.NET.SDL" Version="2.21.0" />
		<!-- Silk.NET.Windowing.Sdl owns window and GL-context creation (Window.Create +
		     window.Initialize()). This is required for Silk.NET.Input.Sdl to ever receive SDL
		     events: SdlWindowing.CreateFrom wraps an externally-created native handle without
		     running the normal Initialize() path, so RegisterCallbacks() (which subscribes the
		     view to SDL's event pump) never runs and input silently never arrives, no matter what
		     is polled afterward (#3652). -->
		<PackageReference Include="Silk.NET.Windowing.Sdl" Version="2.21.0" />
	</ItemGroup>

	<!-- Gum.SilkNet: the real game-host runtime (GumService.Silk.cs, Silk-backed Cursor/Keyboard,
	     Forms V3 default visuals). Replaces the old SkiaGum + render-only standalone GumService
	     wiring, which had no input context at all (#3652). -->
	<ItemGroup>
	  <ProjectReference Include="..\..\..\Runtimes\SilkNetGum\SilkNetGum.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <None Update="Content\GumProject\**\*.*">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	  <None Update="libEGL.dll">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	  <None Update="libGLESv2.dll">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	  <None Update="Super Morning.ttf">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	  <None Update="Winter Selfie.ttf">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Content\GumProject\" />
	</ItemGroup>

</Project>
