<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>SokolGumSample</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\GumCommon\GumCommon.csproj" />
    <ProjectReference Include="..\..\Runtimes\SokolGum\SokolGum.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**\*.*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <PropertyGroup>
    <SokolLibsDir>$(MSBuildThisFileDirectory)..\..\Sokol.NET\libs</SokolLibsDir>
  </PropertyGroup>

  <Import Project="..\..\Runtimes\SokolGum\Sokol.Native.targets" />

</Project>
