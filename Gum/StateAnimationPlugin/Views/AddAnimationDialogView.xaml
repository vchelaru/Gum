<UserControl
    x:Class="StateAnimationPlugin.Views.AddAnimationDialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Gum.Services.Dialogs;assembly=Gum"
    xmlns:local="clr-namespace:StateAnimationPlugin.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:StateAnimationPlugin.ViewModels"
    xmlns:converters="clr-namespace:Gum.Converters;assembly=Gum"
    Width="300"
    MinHeight="120"
    d:DataContext="{d:DesignInstance Type={x:Type viewmodels:AddAnimationDialogViewModel},
                                     IsDesignTimeCreatable=False}"
    dialogs:Dialog.DialogTitle="New Animation"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" Invert="False" />
    </UserControl.Resources>
    <StackPanel Margin="4">
        <TextBlock Margin="0,0,0,4" Text="Animation name:" />
        <TextBox Margin="0,0,0,8" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,8"
            Foreground="Red"
            Text="{Binding ValidationMessage}"
            TextWrapping="Wrap"
            Visibility="{Binding ValidationMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <CheckBox IsChecked="{Binding Loops, Mode=TwoWay}">Loop animation</CheckBox>
    </StackPanel>
</UserControl>
