<UserControl
    x:Class="Gum.Plugins.AlignmentButtons.DockControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Gum.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpf="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource AlignmentIconButton}" TargetType="{x:Type Button}" />
    </UserControl.Resources>
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border
            Margin="0,0,8,0"
            Padding="2"
            BorderBrush="{DynamicResource Frb.Brushes.Border.Secondary}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid x:Name="DockGrid">
                <!--  Cross arrangement: 5 buttons in a + shape; corners intentionally empty.  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="LeftButton"
                    Grid.Row="1"
                    Grid.Column="0"
                    Click="LeftButton_Click">
                    <controls:GumIcon Icon="DockLeft" />
                    <Button.ToolTip>Dock Left</Button.ToolTip>
                </Button>
                <Button
                    x:Name="TopButton"
                    Grid.Row="0"
                    Grid.Column="1"
                    Click="TopButton_Click">
                    <controls:GumIcon Icon="DockTop" />
                    <Button.ToolTip>Dock Top</Button.ToolTip>
                </Button>
                <Button
                    x:Name="RightButton"
                    Grid.Row="1"
                    Grid.Column="2"
                    Click="RightButton_Click">
                    <controls:GumIcon Icon="DockRight" />
                    <Button.ToolTip>Dock Right</Button.ToolTip>
                </Button>
                <Button
                    x:Name="BottomButton"
                    Grid.Row="2"
                    Grid.Column="1"
                    Click="BottomButton_Click">
                    <controls:GumIcon Icon="DockBottom" />
                    <Button.ToolTip>Dock Bottom</Button.ToolTip>
                </Button>
                <Button
                    x:Name="FillButton"
                    Grid.Row="1"
                    Grid.Column="1"
                    Click="FillButton_Click">
                    <controls:GumIcon Icon="DockFill" />
                    <Button.ToolTip>Fill</Button.ToolTip>
                </Button>
            </Grid>
        </Border>


        <Border
            Grid.Column="1"
            Padding="2"
            BorderBrush="{DynamicResource Frb.Brushes.Border.Secondary}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel>
                <Button
                    x:Name="FillHorizontallyButton"
                    Click="FillHorizontallyButton_Click">
                    <controls:GumIcon Icon="DockLeftRight" />
                    <Button.ToolTip>
                        Fill Horizontally
                    </Button.ToolTip>
                </Button>
                <Button
                    x:Name="FillVerticallyButton"
                    Click="FillVerticallyButton_Click">
                    <controls:GumIcon Icon="DockTopBottom" />
                    <Button.ToolTip>
                        Fill Vertically
                    </Button.ToolTip>
                </Button>

                <Button
                    x:Name="SizeToChildrenButton"
                    Click="SizeToChildren_Click"
                    Content="{wpf:FluentIcon Icon=ArrowMoveInward}">
                    <Button.ToolTip>
                        Size to Children
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
