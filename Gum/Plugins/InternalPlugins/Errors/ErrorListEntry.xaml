<UserControl
    x:Class="Gum.Plugins.Errors.ErrorListEntry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gum.Plugins.Errors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Column="0"
            Margin="4,0,4,0"
            VerticalAlignment="Center"
            FontFamily="Consolas"
            Foreground="Gray"
            Text="{Binding Code}"
            Visibility="{Binding HasCodeWithoutHelpUrl, Converter={StaticResource BoolToVisibility}}" />
        <TextBlock
            Grid.Column="0"
            Margin="4,0,4,0"
            VerticalAlignment="Center"
            FontFamily="Consolas"
            Visibility="{Binding HasHelpUrl, Converter={StaticResource BoolToVisibility}}">
            <Hyperlink NavigateUri="{Binding HelpUrl}" RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="{Binding Code}" />
            </Hyperlink>
        </TextBlock>
        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding Message}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
